# Hugging Face Authentication
HF_TOKEN=your_huggingface_token_here

# Model Configuration
MODEL_CACHE_DIR=/app/models
MEDASR_MODEL=google/medasr
MEDGEMMA_MODEL=google/medgemma-1.5-4b-it

# Device Configuration
DEVICE=cuda  # Use 'cuda' for GPU, 'cpu' for CPU-only
ENABLE_GPU=true

# Audio Processing
MAX_AUDIO_DURATION_SECONDS=300
AUDIO_SAMPLE_RATE=16000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Logging
LOG_LEVEL=INFO

# Compliance Controls
# Set to true ONLY after your organization has reviewed and accepted MedGemma terms:
# https://ai.google.dev/gemma/terms
MEDGEMMA_TERMS_ACKNOWLEDGED=false
ENFORCE_MEDGEMMA_TERMS_ACKNOWLEDGEMENT=true

# HIPAA-focused defaults (minimum necessary): PHI logging/storage disabled
ALLOW_PHI_LOGGING=false
ENABLE_PHI_PERSISTENCE=false

# Authentication & RBAC
AUTH_ENABLED=true
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_HASH_ITERATIONS=390000
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_FULL_NAME=System Administrator

# Audit logging
AUDIT_LOGGING_ENABLED=true

# HIPAA Encryption at Rest
# Enable AES-256-GCM encryption for stored transcripts and SOAP notes
ENCRYPTION_AT_REST_ENABLED=false
ENCRYPTION_MASTER_KEY=CHANGE_ME_IN_PRODUCTION  # Must be a strong random secret
ENCRYPTION_KDF_ITERATIONS=100000

# Data Retention & Auto-Purge
RETENTION_SESSIONS_DAYS=365            # Intake session retention (0 = keep forever)
RETENTION_AUDIT_LOGS_DAYS=2555         # ~7 years (HIPAA requires min 6 years)
AUTO_PURGE_ENABLED=false               # Enable scheduled auto-purge
AUTO_PURGE_INTERVAL_HOURS=24           # How often auto-purge runs

# Rate Limiting & Queue
RATE_LIMITING_ENABLED=true
RATE_LIMIT_GENERAL_RPM=60          # General endpoints: max requests per minute
RATE_LIMIT_INFERENCE_RPM=10        # Inference endpoints: max requests per minute
QUEUE_MAX_CONCURRENT_INFERENCES=2  # Max parallel model inference tasks
QUEUE_MAX_SIZE=20                  # Max queued requests before rejecting
QUEUE_TIMEOUT_SECONDS=120          # Max seconds a request waits in queue
QUEUE_ESTIMATED_INFERENCE_SECONDS=10  # Default estimate before measurements

# Monitoring & Observability
METRICS_ENABLED=true
STRUCTURED_LOGGING_ENABLED=true       # JSON-formatted logs with correlation IDs
METRICS_ENDPOINT_AUTH_REQUIRED=false   # Set true to require auth for /metrics
METRICS_ALERT_WINDOW_SECONDS=300      # Alert evaluation window (5 min)
METRICS_ERROR_RATE_WARNING=0.1        # 10% error rate = warning
METRICS_ERROR_RATE_CRITICAL=0.25      # 25% error rate = critical
METRICS_LATENCY_WARNING_SECONDS=15    # Avg latency warning threshold
METRICS_LATENCY_CRITICAL_SECONDS=30   # Avg latency critical threshold
